@startuml
' Klassediagram for frisørbooking-platform (SP4) - MVP med CSV

' === MODELLER ===

abstract class User {
  # id: int
  # name: String
  # email: String
  # passwordHash: String
  + login(password: String): boolean
  + logout(): void
  + updateProfile(name: String, email: String): void
}

class Customer {
  - postalCode: String
  + register(name: String, email: String, password: String, postalCode: String): Customer
  + getBarbers(category: Category): List<Barber>
  + bookTime(barber: Barber, service: Service, dateTime: LocalDateTime): Booking
  + writeReview(booking: Booking, rating: int, comment: String): Review
  + getBookings(): List<Booking>
}

class Barber {
  - salonName: String
  - description: String
  - postalCode: String
  + register(name: String, email: String, password: String, salonName: String, postalCode: String): Barber
  + updateSalon(salonName: String, description: String, postalCode: String): void
  + addService(name: String, category: Category, price: double, duration: int): Service
  + editService(service: Service): void
  + removeService(service: Service): void
  + setOpeningHours(weekday: Weekday, open: LocalTime, close: LocalTime): void
  + getAvailableSlots(date: LocalDate, service: Service): List<LocalTime>
  + getUpcomingBookings(): List<Booking>
  + getReviews(): List<Review>
  + getAverageRating(): double
  + distanceTo(postalCode: String): double
}

class Service {
  - id: int
  - name: String
  - category: Category
  - price: double
  - durationMinutes: int
}

class Booking {
  - id: int
  - dateTime: LocalDateTime
  - status: BookingStatus
  - totalPrice: double
  + complete(): void
  + isInPast(): boolean
  + canBeReviewed(): boolean
}

class Review {
  - id: int
  - rating: int
  - comment: String
  - createdAt: LocalDateTime
}

class OpeningHours {
  - id: int
  - weekday: Weekday
  - openTime: LocalTime
  - closeTime: LocalTime
}

' === ENUMS ===

enum Category {
  FADE
  BUZZ_CUT
  LONG_HAIR
  BEARD
  COLORING
  STYLING
}

enum BookingStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

' === FIL-HÅNDTERING ===

class FileHandler {
  - USERS_FILE: String = "data/users.csv"
  - BARBERS_FILE: String = "data/barbers.csv"
  - CUSTOMERS_FILE: String = "data/customers.csv"
  - SERVICES_FILE: String = "data/services.csv"
  - BOOKINGS_FILE: String = "data/bookings.csv"
  - REVIEWS_FILE: String = "data/reviews.csv"
  - OPENING_HOURS_FILE: String = "data/opening_hours.csv"
  + loadUsers(): List<User>
  + saveUser(user: User): void
  + findUserByEmail(email: String): User
  + loadBarbers(): List<Barber>
  + findBarberById(id: int): Barber
  + saveBarber(barber: Barber): void
  + updateBarber(barber: Barber): void
  + loadServicesByBarber(barberId: int): List<Service>
  + saveService(service: Service): void
  + deleteService(id: int): void
  + loadBookingsByCustomer(customerId: int): List<Booking>
  + loadBookingsByBarber(barberId: int): List<Booking>
  + saveBooking(booking: Booking): void
  + loadReviewsByBarber(barberId: int): List<Review>
  + saveReview(review: Review): void
  + loadOpeningHours(barberId: int): List<OpeningHours>
  + saveOpeningHours(oh: OpeningHours): void
  - readCSV(file: String): List<String[]>
  - writeCSV(file: String, rows: List<String[]>): void
  - nextId(file: String): int
}

' === ARV ===
User <|-- Customer
User <|-- Barber

' === KOMPOSITIONER ===
Barber "1" *-- "0..*" Service : tilbyder >
Barber "1" *-- "0..*" OpeningHours : har >

' === ASSOCIATIONER ===
Customer "1" -- "0..*" Booking : opretter >
Barber "1" -- "0..*" Booking : modtager >
Booking "0..*" -- "1" Service : består af >
Booking "1" -- "0..1" Review : får >

' === ENUM-KOBLINGER ===
Service ..> Category
Booking ..> BookingStatus
OpeningHours ..> Weekday

@enduml